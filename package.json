    "eslint": "^10.7.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-markdownlint": "^0.10.1",
    "eslint-plugin-package-json": "^0.88.3",
