{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowJs": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "module": "nodenext",
    "target": "esnext",
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["./src/**/*.spec.ts"]
}
