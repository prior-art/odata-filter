{
  "name": "@odata-filter/cli",
  "version": "1.1.0",
  "type": "module",
  "keywords": [
    "odata",
    "rest-api",
    "nodejs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prior-art/odata-filter.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/prior-art/odata-filter/issues"
  },
  "description": "Command-line interface for parsing, validating, and transforming OData filter expressions, providing a convenient tool for developers to work with OData filters in various formats.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "odata-filter-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist node_modules reports coverage",
    "dev": "ts-node ./src/index.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:mutation": "stryker run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@odata-filter/core": "^1.0.0",
    "@odata-filter/core-wasm": "^1.2.0",
    "@odata-filter/marshalers": "^1.0.0",
    "@odata-filter/validation": "^1.0.0"
  },
  "peerDependencies": {
    "@odata-filter/core": "^1.0.0",
    "@odata-filter/core-wasm": "^1.2.0",
    "@odata-filter/marshalers": "^1.0.0",
    "@odata-filter/validation": "^1.0.0"
  }
}
